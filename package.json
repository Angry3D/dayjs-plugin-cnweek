{
  "name": "@relaxcoder/dayjs-plugin-cnweek",
  "version": "1.0.0",
  "description": "a plugin of dayjs, to get or set the chinese week",
  "private": false,
  "packageManager": "pnpm@8.15.9",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.mjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "author": "relax<385906070@qq.com>",
  "license": "MIT",
  "scripts": {
    "prepack": "pnpm run build",
    "clean": "rm -rf build dist",
    "build": "pnpm run clean && pnpm run build:ts && rollup -c rollup.config.mjs",
    "build:ts": "tsc -p tsconfig.build.json",
    "test": "pnpm run build:ts && jest",
    "typecheck": "tsc --noEmit",
    "pack:dry-run": "npm_config_cache=.npm-cache npm pack --dry-run",
    "verify": "pnpm test && pnpm run typecheck && pnpm run pack:dry-run"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Angry3D/dayjs-plugin-cnweek.git"
  },
  "keywords": [
    "dayjs",
    "plugin",
    "chinese",
    "week"
  ],
  "bugs": {
    "url": "https://github.com/Angry3D/dayjs-plugin-cnweek/issues"
  },
  "homepage": "https://github.com/Angry3D/dayjs-plugin-cnweek#readme",
  "peerDependencies": {
    "dayjs": "*"
  },
  "devDependencies": {
    "@babel/core": "^7.23.3",
    "@babel/preset-env": "^7.23.3",
    "@rollup/plugin-babel": "^6.0.4",
    "@rollup/plugin-terser": "^0.4.4",
    "babel-jest": "^29.7.0",
    "dayjs": "^1.11.10",
    "jest": "^29.7.0",
    "prettier": "^3.1.0",
    "rollup": "^3.29.4",
    "typescript": "5.6.3"
  }
}
